{
    "version": 2,
    "buildCommand": "npm run build:vercel",
    "outputDirectory": "dist/public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/handler"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/handler.js": {
            "maxDuration": 30
        }
    }
}